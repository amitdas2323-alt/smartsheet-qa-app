# Smartsheet (required for summary and prompt)
SMARTSHEET_ACCESS_TOKEN=your_smartsheet_api_token
SMARTSHEET_SHEET_ID=your_sheet_id

# Optional: for natural-language answers when using "prompt"
OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini

# Weekly summary email (required for send_summary_email.py)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your_email@company.com
SMTP_PASSWORD=your_password_or_app_password
SUMMARY_RECIPIENTS=manager1@company.com,manager2@company.com
# SUMMARY_FROM_EMAIL=your_email@company.com
